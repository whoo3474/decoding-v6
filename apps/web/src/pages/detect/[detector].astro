---
import { detectorSpecs, type DetectorSpec } from '@decoding/spec-registry'
import DetectorPage from '../../components/DetectorPage.astro'

export function getStaticPaths() {
  return detectorSpecs.map((spec) => ({ params: { detector: spec.slug }, props: { spec } }))
}

const { spec } = Astro.props as { spec: DetectorSpec }
---

<DetectorPage locale="en" spec={spec} />
