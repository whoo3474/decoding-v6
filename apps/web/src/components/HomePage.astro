---
import WebDecoder from '../islands/WebDecoder'
import Layout from '../layouts/Layout.astro'
import { homeMessages, localePath, type Locale } from '../i18n/catalog'
import { decoderMessages } from '@decoding/workbench-ui'

interface Props {
  locale: Locale
}
const { locale } = Astro.props
const messages = homeMessages[locale]
const [heading, accentHeading] = messages.heading.split('\n')
---

<Layout locale={locale} title={messages.title} description={messages.description} alternatePath="/">
  <section class="hero container">
    <div class="hero-copy">
      <span class="eyebrow hero-eyebrow">{messages.eyebrow}</span>
      <h1>{heading}<br /><span>{accentHeading}</span></h1>
      <p>{messages.intro}</p>
      <div class="hero-proof">
        <span><strong>8</strong> {messages.detectorCount}</span>
        <span><strong>47</strong> {messages.utilityCount}</span>
        <span><strong>0</strong> {messages.uploaded}</span>
      </div>
    </div>
    <div class="hero-aside" aria-label={messages.principles}>
      <div><span>01</span><strong>{messages.autoTitle}</strong><p>{messages.autoBody}</p></div>
      <div><span>02</span><strong>{messages.chainTitle}</strong><p>{messages.chainBody}</p></div>
      <div>
        <span>03</span><strong>{messages.confidenceTitle}</strong><p>{messages.confidenceBody}</p>
      </div>
    </div>
  </section>
  <div class="container workbench-wrap">
    <WebDecoder messages={decoderMessages[locale]} client:only="preact" />
  </div>
  <section class="container value-section">
    <div class="section-heading">
      <span class="eyebrow">{messages.sensitive}</span>
      <h2>{messages.workbench}</h2>
    </div>
    <div class="value-grid">
      <article>
        <span class="value-index">A</span><h3>{messages.evidenceTitle}</h3><p>
          {messages.evidenceBody}
        </p>
      </article>
      <article>
        <span class="value-index">B</span><h3>{messages.warningTitle}</h3><p>
          {messages.warningBody}
        </p>
      </article>
      <article>
        <span class="value-index">C</span><h3>{messages.toolsTitle}</h3><p>{messages.toolsBody}</p>
        <a href={localePath(locale, '/tools/')}>{messages.toolsLink}</a>
      </article>
    </div>
  </section>
</Layout>
